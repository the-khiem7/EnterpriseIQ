<mxfile host="app.diagrams.net" type="device">
  <diagram name="EnterpriseIQ Architecture" id="enterpriseiq-arch">
    <mxGraphModel dx="1100" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="EnterpriseIQ — GraphRAG Company Brain (Track 4: Open Innovation)" style="text;html=1;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="760" height="30" as="geometry" />
        </mxCell>

        <!-- Browser -->
        <mxCell id="browser" value="User / Browser&#10;(compliance, legal, ops teams)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- Vercel group -->
        <mxCell id="vercel" value="Vercel  —  region cle1" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;strokeColor=#000000;fillColor=none;verticalAlign=top;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="240" y="110" width="300" height="330" as="geometry" />
        </mxCell>
        <mxCell id="ui" value="Next.js App (React, Tailwind)&#10;UI: Ask · Documents · Graph · Status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eef7;strokeColor=#2b5cad;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="265" y="150" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="api" value="Serverless API Routes&#10;/api/ingest · /api/query&#10;/api/graph · /api/feedback · /api/status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eef7;strokeColor=#2b5cad;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="265" y="255" width="250" height="100" as="geometry" />
        </mxCell>
        <mxCell id="oidc" value="OIDC → AWS STS&#10;→ IAM token (rds-signer)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="265" y="375" width="250" height="50" as="geometry" />
        </mxCell>

        <!-- AWS group -->
        <mxCell id="aws" value="AWS  —  us-east-2" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;strokeColor=#ED7100;fillColor=none;verticalAlign=top;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="620" y="90" width="430" height="400" as="geometry" />
        </mxCell>

        <!-- Aurora -->
        <mxCell id="aurora" value="Amazon Aurora PostgreSQL — Serverless v2 (PG 17)&#10;ONE engine: relational + vector + graph" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#1a73e8;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="645" y="130" width="380" height="230" as="geometry" />
        </mxCell>
        <mxCell id="rel" value="Relational tables&#10;documents · chunks · query_logs · feedback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1a73e8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="665" y="180" width="340" height="45" as="geometry" />
        </mxCell>
        <mxCell id="vec" value="pgvector — embeddings (HNSW, cosine)&#10;text-embedding-3-small (1536-d)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1a73e8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="665" y="235" width="340" height="45" as="geometry" />
        </mxCell>
        <mxCell id="graph" value="Knowledge graph — entities + edges&#10;pgRouting + WITH RECURSIVE (multi-hop)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1a73e8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="665" y="290" width="340" height="45" as="geometry" />
        </mxCell>

        <!-- IAM -->
        <mxCell id="iam" value="AWS IAM — database authentication&#10;(passwordless; scoped rds-db:connect)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="410" width="270" height="55" as="geometry" />
        </mxCell>

        <!-- OpenAI external -->
        <mxCell id="openai" value="OpenAI&#10;gpt-4o — triple extraction + answer synthesis&#10;text-embedding-3-small — embeddings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#1e8449;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1110" y="250" width="170" height="110" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" value="HTTPS" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=11;" edge="1" parent="1" source="browser" target="ui">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="fetch" style="endArrow=block;html=1;rounded=0;fontSize=11;" edge="1" parent="1" source="ui" target="api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="SQL over TLS&#10;(IAM token auth)" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=11;strokeColor=#1a73e8;" edge="1" parent="1" source="api" target="aurora">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="embeddings + LLM" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=11;strokeColor=#1e8449;" edge="1" parent="1" source="api" target="openai">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="580" y="470" />
              <mxPoint x="1195" y="470" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e5" value="token" style="endArrow=block;html=1;dashed=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=11;strokeColor=#d6b656;" edge="1" parent="1" source="oidc" target="iam">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="authorizes connect" style="endArrow=block;html=1;dashed=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=11;strokeColor=#d6b656;" edge="1" parent="1" source="iam" target="aurora">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
